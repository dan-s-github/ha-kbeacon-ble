#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

# Install uv package manager if not already installed
if ! command -v uv &> /dev/null; then
    echo "Installing uv..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="$HOME/.local/bin:$PATH"
fi

# Sync dependencies including dev dependencies
uv sync --all-extras

